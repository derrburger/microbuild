# MicroBuild — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Supabase project URL — found in your Supabase dashboard under Settings > API
VITE_SUPABASE_URL=

# Supabase anon/public key — safe to expose in client-side code
VITE_SUPABASE_ANON_KEY=

# Admin email allowlist — comma-separated list of emails that can access /admin
# These must match the email(s) you create in Supabase Authentication > Users
# Example: VITE_ADMIN_EMAILS=you@example.com,partner@example.com
VITE_ADMIN_EMAILS=
